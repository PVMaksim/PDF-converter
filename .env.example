# ===========================================================================
# PDF Converter Bot — Environment Variables Template
# ===========================================================================
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в Git!
# ===========================================================================

# ---------------------------------------------------------------------------
# App settings
# ---------------------------------------------------------------------------
# Секретный ключ для JWT и сессий. Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Режим отладки (true/false). В production всегда false!
DEBUG=false

# Разрешённые хосты для CORS. "*" для всех или через запятую
ALLOWED_HOSTS=*

# ---------------------------------------------------------------------------
# Telegram settings
# ---------------------------------------------------------------------------
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# URL webhook для Telegram (например, https://yourdomain.com)
TELEGRAM_WEBHOOK_URL=https://yourdomain.com

# Telegram ID администратора для уведомлений об ошибках
# Узнать: @userinfobot в Telegram
ADMIN_TELEGRAM_ID=123456789

# ---------------------------------------------------------------------------
# Database settings
# ---------------------------------------------------------------------------
# Пароль для PostgreSQL (используется в docker-compose.yml)
POSTGRES_PASSWORD=your-secure-password-here

# ---------------------------------------------------------------------------
# Redis / Celery settings
# ---------------------------------------------------------------------------
# URL Redis для брокера и бэкенда
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---------------------------------------------------------------------------
# MinIO / S3 storage settings
# ---------------------------------------------------------------------------
# Endpoint MinIO (внутренний для Docker)
MINIO_ENDPOINT=minio:9000

# Ключи доступа MinIO. Измените с дефолтных в production!
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# Имя бакета для хранения файлов
MINIO_BUCKET=pdf-converter

# Использовать HTTPS для MinIO (true/false)
MINIO_SECURE=false

# ---------------------------------------------------------------------------
# Gotenberg settings
# ---------------------------------------------------------------------------
# URL сервиса Gotenberg (внутренний для Docker)
GOTENBERG_URL=http://gotenberg:3000

# ---------------------------------------------------------------------------
# File limits — free tier
# ---------------------------------------------------------------------------
# Максимальный размер файла для бесплатных пользователей (МБ)
MAX_FILE_SIZE_FREE_MB=50

# Время хранения файлов для бесплатных пользователей (часов)
FILE_TTL_FREE_HOURS=24

# Лимит конвертаций в час для бесплатных пользователей
RATE_LIMIT_FREE_PER_HOUR=10

# ---------------------------------------------------------------------------
# File limits — pro tier
# ---------------------------------------------------------------------------
# Максимальный размер файла для PRO пользователей (МБ)
MAX_FILE_SIZE_PRO_MB=200

# Время хранения файлов для PRO пользователей (дней)
FILE_TTL_PRO_DAYS=7

# Лимит конвертаций в час для PRO пользователей
RATE_LIMIT_PRO_PER_HOUR=100

# ---------------------------------------------------------------------------
# API settings
# ---------------------------------------------------------------------------
# Хост и порт API
API_HOST=0.0.0.0
API_PORT=8000

# Перезагрузка при изменении кода (true только для development)
API_RELOAD=false
