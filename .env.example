# App
SECRET_KEY=change-me-in-production
DEBUG=false
ALLOWED_HOSTS=yourdomain.com

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/pdf_bot

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pdf-converter
MINIO_SECURE=false

# Gotenberg
GOTENBERG_URL=http://gotenberg:3000

# File limits
MAX_FILE_SIZE_FREE_MB=50
MAX_FILE_SIZE_PRO_MB=200
FILE_TTL_FREE_HOURS=24
FILE_TTL_PRO_DAYS=7
RATE_LIMIT_FREE_PER_HOUR=10
RATE_LIMIT_PRO_PER_HOUR=100
